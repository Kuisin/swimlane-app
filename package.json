{
  "name": "kai-swimlane",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "extensions/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @kai-swimlane/web",
    "build": "npm run build -w @kai-swimlane/web",
    "lint": "npm run lint -w @kai-swimlane/web",
    "preview": "npm run preview -w @kai-swimlane/web",
    "build:extension": "npm run build -w vscode-kai-swimlane",
    "package:extension": "npm run package -w vscode-kai-swimlane",
    "verify:extension": "bash scripts/verify-extension.sh",
    "bundle:cursor-plugin": "bash scripts/bundle-cursor-plugin.sh",
    "zip:cursor-plugin": "bash scripts/zip-cursor-plugin.sh",
    "package:cursor-plugin": "npm run package:extension && npm run bundle:cursor-plugin && npm run zip:cursor-plugin",
    "install:cursor-plugin": "npm run package:cursor-plugin && bash scripts/install-cursor-plugin.sh"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.17",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
